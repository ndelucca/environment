{
    "$help": "https://aka.ms/terminal-documentation",
    "$schema": "https://aka.ms/terminal-profiles-schema",
    "defaultProfile": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
    "copyOnSelect": false,
    "copyFormatting": "none",

    "profiles": {
        "defaults": {
            "font": {
                "face": "CaskaydiaCove Nerd Font",
                "size": 12,
                "features": { "ss01": 1 }
            },
            "padding": "5",
            "cursorShape": "bar",
            "opacity": 95,
            "useAcrylic": false,
            "scrollbarState": "hidden",
            "snapOnInput": true,
            "colorScheme": "nd-dark",
            "historySize": 10000
        },
        "list": [
            {
                "guid": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
                "name": "PowerShell",
                "source": "Windows.Terminal.PowershellCore",
                "hidden": false
            },
            {
                "guid": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",
                "name": "Windows PowerShell",
                "commandline": "powershell.exe",
                "hidden": true
            },
            {
                "guid": "{0caa0dad-35be-5f56-a8ff-afceeeaa6101}",
                "name": "Command Prompt",
                "commandline": "cmd.exe",
                "hidden": true
            }
        ]
    },

    "schemes": [
        {
            "name": "nd-dark",
            "background": "#121212",
            "foreground": "#FFFFFF",
            "cursorColor": "#4A9D4A",
            "selectionBackground": "#4A9D4A",
            "black": "#2A2A2A",
            "red": "#FF6B6B",
            "green": "#4A9D4A",
            "yellow": "#F5C842",
            "blue": "#5294CF",
            "purple": "#B084D6",
            "cyan": "#47B3C4",
            "white": "#D0D0D0",
            "brightBlack": "#404040",
            "brightRed": "#FF8A8A",
            "brightGreen": "#6CB66C",
            "brightYellow": "#F7D662",
            "brightBlue": "#72AAEF",
            "brightPurple": "#C89AE6",
            "brightCyan": "#67D3E4",
            "brightWhite": "#FFFFFF"
        }
    ],

    "_comment_keybindings": "Panes estilo tmux. OJO: Windows Terminal NO tiene attach/detach ni sesiones persistentes como tmux; esto solo cubre splits y navegacion en vivo.",
    "actions": [
        { "command": { "action": "splitPane", "split": "vertical",   "splitMode": "duplicate" }, "keys": "alt+\\" },
        { "command": { "action": "splitPane", "split": "horizontal", "splitMode": "duplicate" }, "keys": "alt+-" },

        { "command": { "action": "moveFocus", "direction": "left" },  "keys": "alt+h" },
        { "command": { "action": "moveFocus", "direction": "down" },  "keys": "alt+j" },
        { "command": { "action": "moveFocus", "direction": "up" },    "keys": "alt+k" },
        { "command": { "action": "moveFocus", "direction": "right" }, "keys": "alt+l" },

        { "command": { "action": "resizePane", "direction": "left" },  "keys": "alt+shift+h" },
        { "command": { "action": "resizePane", "direction": "down" },  "keys": "alt+shift+j" },
        { "command": { "action": "resizePane", "direction": "up" },    "keys": "alt+shift+k" },
        { "command": { "action": "resizePane", "direction": "right" }, "keys": "alt+shift+l" },

        { "command": "togglePaneZoom", "keys": "alt+z" },
        { "command": { "action": "closePane" }, "keys": "alt+x" },
        { "command": { "action": "newTab" },    "keys": "alt+t" }
    ]
}
