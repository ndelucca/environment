#!/usr/bin/env bash
#
# Auto-configure Sway outputs. Detects the laptop panel (eDP/LVDS/DSI) and any
# external output dynamically from `swaymsg -t get_outputs` — no hardcoded
# output names or resolutions, so it works across different machines.
#

HDMI_POSITION="left"  # external monitor on the "left" or "right" of the laptop

outputs=$(swaymsg -r -t get_outputs)

# Laptop internal panel: first output whose name looks like an embedded panel.
LAPTOP_OUTPUT=$(echo "$outputs" | jq -r '.[] | select(.name | test("^(eDP|LVDS|DSI)")) | .name' | head -n1)
# External: first output that is not the laptop panel.
EXTERNAL_OUTPUT=$(echo "$outputs" | jq -r --arg lap "$LAPTOP_OUTPUT" '.[] | select(.name != $lap) | .name' | head -n1)

output_connected() {
    local name="$1"
    [ -n "$name" ] || return 1
    echo "$outputs" | jq -e --arg n "$name" '.[] | select(.name == $n)' >/dev/null
}

# Width in px of an output's current (or preferred) mode; 0 if unknown.
output_width() {
    local name="$1"
    echo "$outputs" | jq -r --arg n "$name" \
        '.[] | select(.name == $n) | (.current_mode.width // .modes[-1].width // 0)' | head -n1
}

check_lid_state() {
    local lid_state
    lid_state=$(cat /proc/acpi/button/lid/*/state 2>/dev/null | awk '{print $2}')
    [ "$lid_state" = "closed" ]
}

laptop_connected=$(output_connected "$LAPTOP_OUTPUT" && echo "yes" || echo "no")
external_connected=$(output_connected "$EXTERNAL_OUTPUT" && echo "yes" || echo "no")
lid_closed=$(check_lid_state && echo "yes" || echo "no")

# ============================================================================
# Case 1: Lid is closed
# ============================================================================
if [ "$lid_closed" = "yes" ]; then
    echo "Lid is closed - disabling laptop display, using external monitor only"
    [ -n "$LAPTOP_OUTPUT" ] && swaymsg output "$LAPTOP_OUTPUT" disable
    if [ "$external_connected" = "yes" ]; then
        swaymsg output "$EXTERNAL_OUTPUT" enable
        swaymsg output "$EXTERNAL_OUTPUT" pos 0 0
    fi
    exit 0
fi

# ============================================================================
# Case 2: Both monitors connected (lid is open)
# ============================================================================
if [ "$laptop_connected" = "yes" ] && [ "$external_connected" = "yes" ]; then
    echo "Both monitors detected - positioning $EXTERNAL_OUTPUT on the $HDMI_POSITION"

    laptop_width=$(output_width "$LAPTOP_OUTPUT")
    external_width=$(output_width "$EXTERNAL_OUTPUT")

    swaymsg output "$LAPTOP_OUTPUT" enable
    swaymsg output "$EXTERNAL_OUTPUT" enable

    if [ "$HDMI_POSITION" = "left" ]; then
        # External on left, laptop on right
        swaymsg output "$EXTERNAL_OUTPUT" pos 0 0
        swaymsg output "$LAPTOP_OUTPUT" pos "$external_width" 0
    else
        # Laptop on left, external on right
        swaymsg output "$LAPTOP_OUTPUT" pos 0 0
        swaymsg output "$EXTERNAL_OUTPUT" pos "$laptop_width" 0
    fi
    exit 0
fi

# ============================================================================
# Case 3: Only laptop screen available
# ============================================================================
if [ "$laptop_connected" = "yes" ]; then
    echo "Only laptop screen available - positioning at 0,0"
    swaymsg output "$LAPTOP_OUTPUT" enable
    swaymsg output "$LAPTOP_OUTPUT" pos 0 0
    exit 0
fi

# ============================================================================
# Case 4: Only external monitor available
# ============================================================================
if [ "$external_connected" = "yes" ]; then
    echo "Only external monitor available - positioning at 0,0"
    swaymsg output "$EXTERNAL_OUTPUT" enable
    swaymsg output "$EXTERNAL_OUTPUT" pos 0 0
    exit 0
fi

exit 1
