#!/usr/bin/env bash
set -euo pipefail

#
# nd-public-ip - Monitor de cambios de IP pública
#
# El chequeo lo dispara el systemd user timer nd-public-ip.timer (al iniciar
# sesión y cada hora). Al detectar un cambio avisa por notificación de
# escritorio (notify-send/dunst).
#
# Uso:
#   nd-public-ip          - Chequea IP y notifica si cambió
#   nd-public-ip update   - Acepta la IP nueva pendiente (o guarda la actual)
#   nd-public-ip show     - Muestra la IP actual sin comparar
#

CACHE_DIR="${HOME}/.cache/nd-public-ip"
LAST_IP_FILE="${CACHE_DIR}/last_ip"
NEW_IP_FILE="${CACHE_DIR}/new_ip"

mkdir -p "$CACHE_DIR"

get_public_ip() {
    # Try several services; use the first that returns something that LOOKS like an
    # IPv4. Validating (not just non-empty) rejects captive-portal / error pages that
    # answer 200 with HTML — those would otherwise get cached as "the IP" and fire a
    # bogus change notification. Never returns non-zero (prints empty on total
    # failure) so callers' own empty-string checks decide.
    local svc ip
    for svc in ifconfig.me icanhazip.com ident.me; do
        ip=$(curl -s --max-time 5 "$svc" 2>/dev/null) || true
        ip="${ip//[$'\r\n\t ']/}"   # algunos servicios agregan saltos/espacios
        if [[ "$ip" =~ ^[0-9]{1,3}(\.[0-9]{1,3}){3}$ ]]; then
            printf '%s' "$ip"
            return 0
        fi
    done
    return 0
}

notify_change() {
    # Notificación de escritorio (notify-send/dunst). Desde un user service usa
    # el bus de sesión de systemd --user, así que no necesita exportar
    # WAYLAND_DISPLAY/DISPLAY. Si notify-send no está, no es fatal.
    local old_ip="$1" new_ip="$2" body
    command -v notify-send >/dev/null 2>&1 || return 0
    # notify-send no interpreta \n: armamos el cuerpo con saltos de línea reales.
    printf -v body 'Anterior: %s\nNueva: %s\n\nEjecutá '\''nd-public-ip update'\'' para aceptar.' \
        "${old_ip}" "${new_ip}"
    notify-send -u critical "IP pública cambió" "${body}" 2>/dev/null || true
}

case "${1:-check}" in
    update)
        if [[ -f "$NEW_IP_FILE" ]]; then
            cp "$NEW_IP_FILE" "$LAST_IP_FILE"
            rm -f "$NEW_IP_FILE"
            echo "IP actualizada. Alerta removida."
        else
            # No hay nueva IP pendiente, guardar la actual
            current_ip=$(get_public_ip)
            if [[ -n "$current_ip" ]]; then
                echo "$current_ip" > "$LAST_IP_FILE"
                rm -f "$NEW_IP_FILE"
                echo "IP guardada: $current_ip"
            else
                echo "Error: No se pudo obtener la IP pública"
                exit 1
            fi
        fi
        ;;

    show)
        get_public_ip
        echo
        ;;

    check|"")
        current_ip=$(get_public_ip)

        if [[ -z "$current_ip" ]]; then
            echo "Error: No se pudo obtener la IP pública"
            exit 1
        fi

        # Primera ejecución - guardar IP sin alertar
        if [[ ! -f "$LAST_IP_FILE" ]]; then
            echo "$current_ip" > "$LAST_IP_FILE"
            echo "Primera ejecución. IP guardada: $current_ip"
            exit 0
        fi

        last_ip=$(cat "$LAST_IP_FILE")

        if [[ "$current_ip" != "$last_ip" ]]; then
            # Notificar solo cuando la IP nueva no es la que ya habíamos registrado como
            # pendiente: si no, cada disparo horario apila otra notificación critical
            # idéntica (dunst/mako no cierran las critical) hasta que se haga `update`.
            prev_new="$(cat "$NEW_IP_FILE" 2>/dev/null || true)"
            echo "$current_ip" > "$NEW_IP_FILE"
            echo "IP cambió: $last_ip -> $current_ip"
            if [[ "$current_ip" != "$prev_new" ]]; then
                notify_change "$last_ip" "$current_ip"
            fi
        else
            echo "IP sin cambios: $current_ip"
        fi
        ;;

    *)
        echo "Uso: $0 [check|update|show]"
        exit 1
        ;;
esac
