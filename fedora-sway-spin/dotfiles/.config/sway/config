set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term foot

# swayidle
set $lock_timeout 600
set $screen_timeout 300

# Modos, combi, iconos, matching y tema viven en ~/.config/rofi/config.rasi
set $menu rofi -show drun

# Autostart. `pkill -x` guards make exec_always idempotent across `reload`
# (otherwise every reload spawns a duplicate daemon).
# wlsunset (night light) lives in the generated config.d/10-wlsunset.conf so its
# coordinates come from vars.sh (LATITUDE/LONGITUDE) instead of being hardcoded.
exec_always pkill -x swaync;         exec swaync
exec_always pkill -x kanshi;         exec kanshi          # output profiles (~/.config/kanshi/config)
exec_always pkill -x swayosd-server; exec swayosd-server  # OSD for volume/brightness/caps (see config.d binds)

# Clipboard history (cliphist). `exec` (not exec_always) so reload doesn't add
# duplicate watchers that would double-store every copy.
exec wl-paste --type text  --watch cliphist store
exec wl-paste --type image --watch cliphist store

default_border pixel 2
default_floating_border pixel 2
titlebar_border_thickness 0
titlebar_padding 10 6
gaps inner 6
smart_gaps on
smart_borders on
workspace_auto_back_and_forth yes
focus_on_window_activation focus

# Match the Wayland cursor to the GTK theme (Adwaita 24). XWayland apps read the
# same values from ~/.config/environment.d/cursor.conf.
seat seat0 xcursor_theme Adwaita 24

# swaymsg -t get_outputs
output * bg /usr/share/backgrounds/wallpaper.png fill

# swaymsg -t get_inputs
input type:touchpad {
    accel_profile flat
    dwt enabled
    tap enabled
    natural_scroll enabled
    middle_emulation enabled
}

# Output arrangement (hotplug/dock) is handled declaratively by kanshi
# (~/.config/kanshi/config + the kanshi user service). Lid state is not visible
# to kanshi, so handle it here: disable the internal panel when the lid closes.
bindswitch --reload --locked lid:on  output eDP-1 disable
bindswitch --reload --locked lid:off output eDP-1 enable

bindsym $mod+Return exec $term
bindsym $mod+q kill
bindsym $mod+d exec $menu
bindsym $mod+Shift+r reload
bindsym $mod+Shift+Escape exec loginctl lock-session
# Clipboard history picker (cliphist + rofi)
bindsym $mod+v exec cliphist list | rofi -dmenu -p "Clipboard" | cliphist decode | wl-copy

floating_modifier $mod normal
# bindsym $mod+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -B 'Yes, exit sway' 'swaymsg exit'

bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right

bindsym $mod+f fullscreen toggle
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+c move position center
bindsym $mod+a focus parent

bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

# Sway has a "scratchpad", which is a bag of holding for windows.
# You can send windows there and get them back later.
# Move the currently focused window to the scratchpad
bindsym $mod+Shift+minus move scratchpad
# Show the next scratchpad window or hide the focused scratchpad window.
# If there are multiple scratchpad windows, this command cycles through them.
bindsym $mod+minus scratchpad show

# Include configs from 3 locations:
#  - /usr/share/sway/config.d
#  - /etc/sway/config.d
#  - $XDG_CONFIG_HOME/sway/config.d ($HOME/.config/sway/config.d)
#
# If multiple directories contain the files with the same name, the later
# directory takes precedence; `$XDG_CONFIG_HOME/sway/config.d/20-swayidle.conf`
# will always be loaded instead of `/usr/share/sway/config.d/20-swayidle.conf`
# or `/etc/sway/config.d/20-swayidle.conf`
#
# This mechanism permits overriding our default configuration per-system
# (/etc) or per-user ($XDG_CONFIG_HOME) basis. Just create the file you
# want to modify/override in the higher-level directory.
#
# For example, to disable the default bar from Fedora configs, you'll need to
#     $ echo -n > "$HOME/.config/sway/config.d/90-bar.conf"
#
# Note the quoting, the $() and the arguments quoting. All the parts are equally
# important to make the magic work. And if you want to learn the secret behind
# the trick, it's all in the `wordexp(3)`.
#
include '$(/usr/libexec/sway/layered-include "/usr/share/sway/config.d/*.conf" "/etc/sway/config.d/*.conf" "${XDG_CONFIG_HOME:-$HOME/.config}/sway/config.d/*.conf")'

# Workspace assignment

workspace 7 output eDP-1 HDMI-A-1
workspace 1 output HDMI-A-1 eDP-1
workspace 2 output HDMI-A-1 eDP-1
workspace 3 output HDMI-A-1 eDP-1
workspace 4 output HDMI-A-1 eDP-1
workspace 5 output HDMI-A-1 eDP-1
workspace 6 output HDMI-A-1 eDP-1
workspace 8 output HDMI-A-1 eDP-1
workspace 9 output HDMI-A-1 eDP-1
workspace 10 output HDMI-A-1 eDP-1

assign [app_id="dev.zed.Zed"]  workspace 3
assign [app_id="neovide"]      workspace 3

# Chromium web-apps report a URL-derived app_id of the form
# `chrome-<host>__-Default` (same for Chromium and Google Chrome PWAs), not the
# --class value, so match them by host. Anchored to not overlap the browser rule
# below, so matching is independent of rule order.
assign [app_id="^chrome-open\.spotify\.com"]    workspace 6
assign [app_id="^chrome-discord\.com"]          workspace 8
assign [app_id="^chrome-teams\.microsoft\.com"] workspace 8
assign [app_id="^chrome-web\.whatsapp\.com"]    workspace 8
assign [app_id="^chrome-mail\.google\.com"]     workspace 10

assign [app_id="net.thunderbird.Thunderbird"] workspace 10

# Real browser windows (not the web-apps). Exact app_id so they never collide
# with the chrome-<host> web-app ids above.
assign [app_id="^(chromium-browser|google-chrome|google-chrome-stable)$"] workspace 2
assign [app_id="^firefox$"] workspace 2
# Modes

mode "resize" {
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# Power menu en rofi (Lock/Logout/Suspend/Reboot/Shutdown), a juego con el sistema
bindsym $mod+BackSpace exec ~/.config/rofi/powermenu.sh

set $mode_settings (a) Audio (n) Notifications
bindsym $mod+exclamdown mode "$mode_settings"
bindsym $mod+questiondown mode "$mode_settings"
bindsym $mod+equal mode "$mode_settings"
mode "$mode_settings" {
    bindsym n exec --no-startup-id swaync-client -t -sw, mode "default"
    bindsym a exec --no-startup-id pavucontrol, mode "default"
    bindsym Return mode "default"
    bindsym Escape mode "default"
}

