# kanshi — perfiles de output declarativos, aplicados automáticamente al hotplug/dock.
# Se arranca desde sway/config (`exec_always ... kanshi`), junto a swaync/wlsunset.
#
# GENERADO desde config.in por setup/05-stow.sh — @DOCK_LEFT_WIDTH@ viene de
# vars.sh (única fuente de verdad). El `config` generado está git-ignored; editá
# el template .in, no el output.
#
# Los perfiles matchean sobre el CONJUNTO de outputs conectados (nombres como en
# `swaymsg -t get_outputs`). El estado de la tapa no es visible para kanshi — eso
# se maneja en sway/config vía `bindswitch lid:on/off`.

# Solo laptop (sin pantalla externa).
profile laptop {
    output eDP-1 enable position 0,0
}

# Docked: monitor externo a la IZQUIERDA, panel de la laptop a su derecha. El offset
# X del panel equivale al ancho del monitor externo (DOCK_LEFT_WIDTH en vars.sh).
profile docked {
    output HDMI-A-1 enable position 0,0
    output eDP-1 enable position @DOCK_LEFT_WIDTH@,0
}

# Solo monitor externo (ej. tapa cerrada y docked — eDP ausente/deshabilitado).
profile external {
    output HDMI-A-1 enable position 0,0
}
